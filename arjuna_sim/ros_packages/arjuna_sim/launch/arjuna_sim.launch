<!-- arjuna_sim.launch — Main entry point for the Arjuna simulator -->
<launch>

  <!-- ======= ARGUMENTS ======= -->
  <arg name="world"     default="$(find arjuna_sim)/worlds/arjuna_world.world"/>
  <arg name="gui"       default="true"/>
  <arg name="rviz"      default="true"/>
  <arg name="x_pos"     default="0.0"/>
  <arg name="y_pos"     default="0.0"/>
  <arg name="z_pos"     default="0.0"/>

  <!-- ======= ROBOT DESCRIPTION ======= -->
  <param name="robot_description"
         command="$(find xacro)/xacro
                  $(find arjuna_description)/urdf/arjuna.urdf.xacro"/>

  <!-- ======= GAZEBO ======= -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(arg world)"/>
    <arg name="paused"     value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui"        value="$(arg gui)"/>
    <arg name="headless"   value="false"/>
    <arg name="debug"      value="false"/>
  </include>

  <!-- Spawn robot in Gazebo -->
  <node name="spawn_arjuna" pkg="gazebo_ros" type="spawn_model"
        args="-urdf -model arjuna
              -x $(arg x_pos) -y $(arg y_pos) -z $(arg z_pos)
              -param robot_description"
        output="screen"/>

  <!-- ======= STATE PUBLISHERS ======= -->
  <node name="robot_state_publisher" pkg="robot_state_publisher"
        type="robot_state_publisher" output="screen">
    <param name="publish_frequency" value="30.0"/>
  </node>

  <node name="joint_state_publisher" pkg="joint_state_publisher"
        type="joint_state_publisher"/>

  <!-- ======= ENCODER TICK BRIDGE ======= -->
  <!-- Converts wheel joint states → /left_ticks and /right_ticks
       to match the real robot's odometry node interface -->
  <node name="encoder_bridge" pkg="arjuna_sim" type="encoder_bridge.py"
        output="screen"/>

  <!-- ======= DEPTH VALUE BRIDGE ======= -->
  <!-- Converts /oak/depth/image_raw → /oak/depth_value (Float32)
       to match the real robot's OAK-D Lite interface -->
  <node name="depth_bridge" pkg="arjuna_sim" type="depth_bridge.py"
        output="screen"/>

  <!-- ======= RViz ======= -->
  <group if="$(arg rviz)">
    <node name="rviz" pkg="rviz" type="rviz"
          args="-d $(find arjuna_sim)/config/arjuna.rviz"
          output="screen"/>
  </group>

</launch>
